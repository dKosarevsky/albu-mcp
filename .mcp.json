{
  "mcpServers": {
    "albumentationsx": {
      "command": "uvx",
      "cwd": ".",
      "args": [
        "--from",
        "albumentationsx-mcp==1.17.0",
        "albumentationsx-mcp"
      ],
      "env_vars": [
        "ALBU_MCP_ALLOWED_ROOTS",
        "ALBU_MCP_ARTIFACT_ROOT",
        "ALBU_MCP_MAX_PREVIEW_RUNS"
      ],
      "tool_timeout_sec": 300
    }
  }
}
