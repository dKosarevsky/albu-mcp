{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dKosarevsky/albu-mcp/blob/main/docs/HOST_MANUAL_RUNS.schema.json",
  "title": "AlbumentationsX MCP host manual run records",
  "type": "object",
  "additionalProperties": false,
  "required": ["manual_host_ui"],
  "properties": {
    "manual_host_ui": {
      "type": "array",
      "description": "Dated manual MCP host UI evidence records. Keep this empty until a reviewer records evidence.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["host", "status", "date", "evidence"],
        "properties": {
          "host": {
            "type": "string",
            "enum": ["Claude Desktop", "Claude Code", "Cursor", "Codex"]
          },
          "status": {
            "type": "string",
            "enum": ["passed", "blocked", "pending"]
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "first_10_minutes_replay": {
      "type": "array",
      "description": "Dated host replay evidence for the First 10 Minutes workflow.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["host", "status", "date", "evidence", "artifacts"],
        "properties": {
          "host": {
            "type": "string",
            "enum": ["Claude Desktop", "Claude Code", "Cursor", "Codex"]
          },
          "status": {
            "type": "string",
            "enum": ["passed", "blocked", "pending"]
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
